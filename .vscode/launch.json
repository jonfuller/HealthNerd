{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (console)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/HealthNerd.Cli/bin/Debug/net6.0/HealthNerd.Cli.dll",
            "args": ["excel-export", "--export-file=${workspaceFolder}/export-2023-08.zip", "--settings-file=${workspaceFolder}/settings.json", "--custom-sheets=./custom_sheets.xlsx", "--output=${workspaceFolder}/output.xlsx"],
            "cwd": "${workspaceFolder}/src/HealthNerd.Cli",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}